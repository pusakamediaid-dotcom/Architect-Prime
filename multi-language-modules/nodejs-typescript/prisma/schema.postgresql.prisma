// PostgreSQL-compatible Prisma schema for production deployments.
// SQLite remains the default for local zero-config usage. To use PostgreSQL:
//   1. Set DATABASE_URL="postgresql://user:password@localhost:5432/architect_prime?schema=public"
//   2. Run: npx prisma generate --schema prisma/schema.postgresql.prisma
//   3. Run: npx prisma migrate deploy --schema prisma/schema.postgresql.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  email           String   @unique
  passwordHash    String
  phone           String?
  dateOfBirth     DateTime?
  addressJson     String?
  role            String   @default("user")
  status          String   @default("active")
  emailVerified   Boolean  @default(false)
  avatar          String?
  metadataJson    String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([createdAt])
}
